# Port the viewer listens on
PORT=3333

# Absolute path to the posters directory (output/generic/ from gravura-backify)
# The directory must contain {type}/{CC}/{city}/*.png structure
POSTERS_DIR=/path/to/gravura-backify/output/generic

# Absolute path to the publish state JSON file (optional — enables published/pending badges)
# Typically .publish-state.json in the gravura-backify root
STATE_FILE=/path/to/gravura-backify/.publish-state.json

# Scan cache TTL in milliseconds (default: 30000 = 30s)
CACHE_TTL=30000

# DAM base URL for direct FTP links (optional)
DAM_BASE_URL=https://dam.gravura-poster.com/upload/posters
